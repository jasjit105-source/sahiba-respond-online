# =====================================================================
# Sahiba Unified CRM — Environment Variables
# =====================================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit real credentials.
#
# In production (Netlify), set these in:
#   Netlify Dashboard → Site Settings → Environment Variables
# =====================================================================

# --- Neon Postgres (required) ---
# Get this from Neon console → your project → Connection Details → Pooled connection
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# --- API Auth Token (required) ---
# Used by frontend to authenticate to Netlify Functions.
# Generate a strong one with: openssl rand -hex 32
APP_TOKEN=replace-with-32-char-random-string

# --- Admin password gate (frontend) ---
# Used by the Respond Tracker admin UI. Set in Netlify env so it can be rotated
# without a code change. (Frontend reads it at build time via VITE_ prefix.)
VITE_ADMIN_PASSWORD=replace-with-strong-password

# --- Pipeboard (Meta Ads) ---
# Currently hardcoded in server.js lines 34-36 — moving to env during migration.
# Rotate the existing token in Pipeboard before committing.
PIPEBOARD_URL=https://mcp.pipeboard.co/meta-ads-mcp
PIPEBOARD_TOKEN=replace-with-rotated-pipeboard-token
META_AD_ACCOUNT_ID=act_4022620911308267
